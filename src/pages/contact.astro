---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm';
import { siteConfig } from '../config/site';

const title = `Contact ${siteConfig.name} | Edinburgh Cleaning Quotes`;
const description =
  'Request a cleaning quote in Edinburgh. Domestic, commercial, holiday let and end-of-tenancy services. Call or send a message today.';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description}>
  <main id="main-content" class="pt-32 pb-20 px-6 max-w-3xl mx-auto">
    <p class="text-amber-500 text-xs tracking-widest uppercase mb-4 text-center">Get in touch</p>
    <h1 class="text-3xl md:text-5xl text-white font-light mb-4 text-center leading-tight">
      Request a quote
    </h1>
    <p class="text-slate-400 text-center font-sans text-sm mb-12 max-w-lg mx-auto">
      Tell us about your property and preferred schedule. We respond within one business day.
    </p>

    <div class="grid md:grid-cols-3 gap-8 mb-12 font-sans text-sm">
      <a
        href={`tel:${siteConfig.phone}`}
        class="border border-white/10 p-6 hover:border-amber-500/50 transition-colors text-center"
      >
        <p class="text-slate-500 text-xs uppercase tracking-widest mb-2">Phone</p>
        <p class="text-white">{siteConfig.phoneDisplay}</p>
      </a>
      <a
        href={`mailto:${siteConfig.email}`}
        class="border border-white/10 p-6 hover:border-amber-500/50 transition-colors text-center"
      >
        <p class="text-slate-500 text-xs uppercase tracking-widest mb-2">Email</p>
        <p class="text-white break-all">{siteConfig.email}</p>
      </a>
      <div class="border border-white/10 p-6 text-center">
        <p class="text-slate-500 text-xs uppercase tracking-widest mb-2">Area</p>
        <p class="text-white">Edinburgh &amp; The Lothians</p>
      </div>
    </div>

    <ContactForm client:load />

    <p class="mt-8 text-center text-slate-500 text-xs font-sans">
      Prefer email?
      <a href={`mailto:${siteConfig.email}`} class="text-amber-500 hover:underline">
        {siteConfig.email}
      </a>
      ·
      <a href={`${base}privacy`} class="hover:text-amber-500 transition-colors">Privacy Policy</a>
    </p>
  </main>
</BaseLayout>
