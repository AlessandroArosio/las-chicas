---
import { siteConfig } from '../config/site';
import { Phone, Mail, Instagram, Facebook } from 'lucide-react';

const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
---

<footer id="contact" class="border-t border-white/10 bg-[#050505] pt-20 pb-10 px-6 mt-12">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12 mb-16">
    <div>
      <div class="text-white font-light text-xl tracking-[0.2em] uppercase mb-6">
        Las Chicas<span class="text-amber-500 font-bold"> Cleaning</span>
      </div>
      <p class="text-slate-400 text-sm font-sans leading-relaxed max-w-xs">
        Elevating the standard of clean for Edinburgh's finest properties. Fully insured and thoroughly vetted.
      </p>
    </div>

    <div class="font-sans">
      <h2 class="text-white text-sm tracking-widest uppercase mb-6 border-b border-white/10 pb-3 inline-block">
        Contact
      </h2>
      <div class="space-y-4 text-slate-400 text-sm">
        <a
          href={`tel:${siteConfig.phone}`}
          class="flex items-center gap-3 hover:text-amber-500 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {siteConfig.phoneDisplay}
        </a>
        <a
          href={`mailto:${siteConfig.email}`}
          class="flex items-center gap-3 hover:text-amber-500 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          {siteConfig.email}
        </a>
        <p class="pt-2">Serving Edinburgh &amp; The Lothians</p>
        <a
          href={`${base}contact`}
          class="inline-block text-amber-500 text-xs tracking-widest uppercase border-b border-amber-500/30 pb-1 hover:text-white transition-colors"
        >
          Send a message
        </a>
      </div>
    </div>

    <div class="font-sans">
      <h2 class="text-white text-sm tracking-widest uppercase mb-6 border-b border-white/10 pb-3 inline-block">
        Connect
      </h2>
      <div class="flex gap-4 mb-6 text-slate-400">
        <a
          href={siteConfig.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-amber-500 transition-colors"
          aria-label="Instagram"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
        </a>
        <a
          href={siteConfig.facebook}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-amber-500 transition-colors"
          aria-label="Facebook"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
      </div>
      <p class="text-slate-500 text-xs">
        &copy; {currentYear} {siteConfig.legalName}.<br />
        Company No. {siteConfig.companyNumber}<br />
        <a href={`${base}privacy`} class="hover:text-amber-500 transition-colors">Privacy Policy</a>
      </p>
    </div>
  </div>
</footer>
