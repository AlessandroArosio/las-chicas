---
import { images, siteConfig } from '../config/site';

const base = import.meta.env.BASE_URL;
---

<header class="relative min-h-[80vh] md:min-h-screen flex items-center justify-center pt-24">
  <div class="absolute inset-0">
    <img
      src={images.heroLuxury}
      alt="Luxury Edinburgh interior cleaned to a high standard"
      class="w-full h-full object-cover"
      width="2000"
      height="1333"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-transparent to-transparent"></div>
  </div>

  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
    <p class="text-amber-500 uppercase tracking-widest text-xs font-sans font-bold mb-6 md:mb-8 drop-shadow-md">
      {siteConfig.tagline}
    </p>
    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-white font-light mb-6 md:mb-8 leading-tight drop-shadow-lg">
      Immaculate standards. <br />
      <span class="italic text-amber-500">Discreet service.</span>
    </h1>
    <p class="text-base md:text-lg text-slate-300 font-sans font-light tracking-wide max-w-xl mx-auto drop-shadow-md">
      High-end cleaning for luxury residences, commercial estates, and five-star holiday lets across Edinburgh and the Lothians.
    </p>
    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center font-sans">
      <a
        href={`${base}contact`}
        class="inline-block px-8 py-3 text-xs tracking-widest uppercase bg-amber-500 text-[#0a0a0a] hover:bg-amber-400 transition-colors"
      >
        Request a quote
      </a>
      <a
        href={`tel:${siteConfig.phone}`}
        class="inline-block px-8 py-3 text-xs tracking-widest uppercase border border-white/30 text-white hover:border-amber-500 hover:text-amber-500 transition-colors"
      >
        Call {siteConfig.phoneDisplay}
      </a>
    </div>
  </div>
</header>
