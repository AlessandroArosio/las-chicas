# Copy to .env and fill in before running locally or deploying.
# For GitHub Actions, add PUBLIC_WEB3FORMS_KEY as a repository secret.

# Web3Forms access key — get one free at https://web3forms.com
PUBLIC_WEB3FORMS_KEY=your_access_key_here

# GitHub Pages project site (default). Change when using a custom domain.
PUBLIC_SITE_URL=https://YOUR_USERNAME.github.io
PUBLIC_BASE_PATH=/laschicas-cleaning

# Custom domain example (uncomment when live):
# PUBLIC_SITE_URL=https://www.laschicascleaning.co.uk
# PUBLIC_BASE_PATH=/
